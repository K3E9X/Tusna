# Tusna configuration — EVERY value here is OPTIONAL.
# Copy to .env.local (dev) or set as container / Vercel env vars. Leave a line empty
# to keep that feature off; the app always runs and degrades gracefully.

# --- Deep-scan collector worker (Maigret / Holehe / SpiderFoot) ---
# Present  → the "Maigret (deep)", Holehe, SpiderFoot apps light up.
# Absent   → built-in keyless connectors only.
COLLECTOR_URL=
COLLECTOR_TOKEN=

# --- Durable storage (cases + append-only snapshot history / chain of custody) ---
# Present  → cases persist server-side across devices and restarts.
# Absent   → cases fall back to the browser (localStorage).
POSTGRES_URL=

# --- Breach / leak search (Intelligence X) — optional, sensitive ---
INTELX_API_KEY=
# INTELX_URL=https://2.intelx.io

# --- BONUS: Recorded Future (enterprise) — optional, never a base source ---
# Present  → adds credential-exposure (email) + risk (domain) enrichment.
# Absent   → silently skipped. Safe to remove any time.
RECORDED_FUTURE_API_KEY=
# RF_API_URL=https://api.recordedfuture.com/v2
# RF_IDENTITY_URL=https://api.recordedfuture.com/identity

# --- Grounded LLM synthesis (OpenAI-compatible: Ollama / Groq / OpenRouter…) ---
# Absent   → the SYNTHESIZE button reports "LLM not configured"; everything else works.
LLM_API_URL=
LLM_MODEL=
LLM_API_KEY=
